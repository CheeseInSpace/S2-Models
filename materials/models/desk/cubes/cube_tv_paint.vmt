PBR
{
	$basetexture "models/desk/cubes/cube_tv_color"
	$bumpmap "models/desk/cubes/cube_tv_normal"
	
	$mraotexture "models/desk/cubes/cube_tv_mrao"
	$model 1
	
	$detail "paint/prop_paint_white"
	$detailblendmode 2
	$detailscale 1
	
	Proxies
	{
		PaintOverlayColor
		{
			resultVar "$detailtint"
		}
	}	
}