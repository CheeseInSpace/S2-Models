PBR
{
	$basetexture "models/desk/cubes/cube_turntable_color"
	$bumpmap "models/desk/cubes/cube_turntable_normal"
	
	$mraotexture "models/desk/cubes/cube_turntable_mrao"
	$model 1
	
	$detail "paint/prop_paint_white"
	$detailblendmode 2
	$detailscale 1
	
	Proxies
	{
		PaintOverlayColor
		{
			resultVar "$detailtint"
		}
	}	
}